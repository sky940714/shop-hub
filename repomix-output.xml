}

.price {
  color: #2563eb;
  font-weight: 700;
  font-size: 1rem;
}

.original-price {
  font-size: 0.75rem;
  color: #9ca3af;
  text-decoration: line-through;
}

.product-rating {
  font-size: 0.75rem;
  margin-top: 0.25rem;
  color: #6b7280;
}

/* 狀態顯示 */
.loading-container {
  padding: 3rem 0;
  text-align: center;
  color: #6b7280;
}

.loader-spinner {
  animation: spin 1s linear infinite;
  margin-bottom: 0.5rem;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* RWD 調整 */
@media (min-width: 640px) {
