  background: transparent;
  border: 1px solid #d1d5db;
  color: #2563eb;
  border-radius: 0.375rem;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-detail:hover {
  background: #eff6ff;
  border-color: #2563eb;
}

/* ===== 新增：刪除按鈕 ===== */
.btn-delete {
  padding: 0.375rem 0.75rem;
  background: transparent;
  border: 1px solid #fca5a5;
  color: #dc2626;
  border-radius: 0.375rem;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-delete:hover {
  background: #fee2e2;
  border-color: #dc2626;
}

/* ===== 新增：分頁 ===== */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-top: 30px;
  padding: 20px;
}

.btn-page {
  padding: 8px 16px;
  background-color: #2563eb;
  color: white;
  border: none;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: background-color 0.2s;
}

.btn-page:hover:not(:disabled) {
  background-color: #1d4ed8;
}

.btn-page:disabled {
  background-color: #d1d5db;
  cursor: not-allowed;
}

.page-info {
  color: #4b5563;
  font-size: 14px;
}

/* ===== 新增：訂單詳情彈窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 20px;
}

.modal-content {
