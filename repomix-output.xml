      window.alert('刪除失敗，請稍後再試');
    }
  };

  // 切換門市啟用狀態
  const handleToggleActive = async (store: PickupStore) => {
    try {
      const token = localStorage.getItem('token');
      const res = await apiFetch(`${API_BASE}/pickup-stores/admin/${store.id}`, {
        method: 'PUT',
