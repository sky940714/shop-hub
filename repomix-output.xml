<file path="src/pages/ProductDetailPage.css">
/* src/pages/ProductDetailPage.css */

/* 全局設定 */
* {
  box-sizing: border-box;
}

html, body {
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
}

.product-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20px;
  /* ⭐ 修正：確保頂部留出瀏海空間 */
  padding-top: calc(20px + env(safe-area-inset-top));
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}

.back-button {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: white;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  cursor: pointer;
  margin-bottom: 20px;
  font-size: 14px;
  transition: all 0.3s;
  width: fit-content;
}

.back-button:hover {
  background: #f5f5f5;
}

.product-detail-container {
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 500px 1fr;
  gap: 40px;
  background: white;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* ===================================
   左側:圖片區域(固定大小)
   =================================== */

.product-image-section {
  width: 500px;
  display: flex;
  flex-direction: column;
  gap: 15px;
  flex-shrink: 0;
}

/* 主圖輪播 - 固定高度 */
.main-swiper {
  width: 100%;
  height: 500px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  background: #fafafa;
}

.main-swiper .swiper-slide {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  padding: 20px;
}

.main-product-image {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
}

/* 輪播導航按鈕 */
.main-swiper .swiper-button-prev,
.main-swiper .swiper-button-next {
  color: white;
  background: rgba(0, 0, 0, 0.5);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  transition: all 0.3s;
}

.main-swiper .swiper-button-prev:after,
.main-swiper .swiper-button-next:after {
  font-size: 18px;
}

.main-swiper .swiper-button-prev:hover,
.main-swiper .swiper-button-next:hover {
  background: rgba(0, 0, 0, 0.8);
}

/* 分頁指示器 */
.main-swiper .swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: white;
  opacity: 0.5;
  transition: all 0.3s;
}

.main-swiper .swiper-pagination-bullet-active {
  opacity: 1;
  width: 24px;
  border-radius: 4px;
  background: #3b82f6;
}

/* 縮圖輪播 - 固定高度 */
.thumbs-swiper {
  width: 100%;
  height: 100px;
  padding: 0;
}

.thumbs-swiper .swiper-slide {
  opacity: 0.5;
  cursor: pointer;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid transparent;
  transition: all 0.3s;
  background: #fafafa;
}

.thumbs-swiper .swiper-slide:hover {
  opacity: 0.8;
}

.thumbs-swiper .swiper-slide-thumb-active {
  opacity: 1;
  border-color: #3b82f6;
  box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
}

.thumb-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 4px;
}

/* ===================================
   右側:商品資訊區域
   =================================== */

.product-info-section {
  display: flex;
  flex-direction: column;
  gap: 20px;
  min-width: 0;
}

.product-title {
  font-size: 24px;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin: 0;
  word-wrap: break-word;
}

/* 評分區域 */
.rating-section {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 20px;
  border-bottom: 1px solid #e5e5e5;
}

.stars {
  display: flex;
  align-items: center;
  gap: 4px;
}

.rating-text {
  color: #fbbf24;
  font-weight: 600;
}

.divider {
  color: #d1d5db;
}

.sales-text {
  color: #6b7280;
  font-size: 14px;
}

/* 價格區域 */
.price-section {
  background: #fef3f2;
  padding: 20px;
  border-radius: 8px;
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.price-label {
  font-size: 20px;
  color: #ef4444;
  font-weight: 500;
}

.price-value {
  font-size: 32px;
  color: #ef4444;
  font-weight: 700;
}

/* 商品描述 */
.description-section {
  padding: 20px 0;
  border-top: 1px solid #e5e5e5;
  border-bottom: 1px solid #e5e5e5;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #333;
}

.description-text {
  color: #6b7280;
  line-height: 1.6;
  word-wrap: break-word;
  white-space: pre-wrap;
}

/* 庫存 */
.stock-section {
  display: flex;
  align-items: center;
  gap: 8px;
}

.stock-label {
  color: #6b7280;
  font-size: 14px;
}

.stock-value {
  color: #333;
  font-weight: 600;
}

/* 數量選擇 */
.quantity-section {
  display: flex;
  align-items: center;
  gap: 16px;
}

.quantity-label {
  color: #333;
  font-weight: 500;
}

.quantity-controls {
  display: flex;
  align-items: center;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  overflow: hidden;
}

.quantity-button {
  width: 40px;
  height: 40px;
  border: none;
  background: white;
  cursor: pointer;
  font-size: 18px;
  transition: background 0.2s;
}

.quantity-button:hover:not(:disabled) {
  background: #f5f5f5;
}

.quantity-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.quantity-input {
  width: 60px;
  height: 40px;
  text-align: center;
  border: none;
  border-left: 1px solid #e5e5e5;
  border-right: 1px solid #e5e5e5;
  font-size: 16px;
  font-weight: 600;
}

/* 操作按鈕 */
.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.add-to-cart-btn,
.buy-now-btn {
  flex: 1;
  padding: 14px 24px;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.3s;
}

.add-to-cart-btn {
  background: white;
  color: #3b82f6;
  border: 2px solid #3b82f6;
}

.add-to-cart-btn:hover {
  background: #eff6ff;
}

.buy-now-btn {
  background: #3b82f6;
  color: white;
}

.buy-now-btn:hover {
  background: #2563eb;
}

/* 載入和錯誤狀態 */
.loading-container,
.error-container {
  min-height: 400px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
}

.loading,
.error {
  font-size: 18px;
  color: #6b7280;
}

.back-home-btn {
  padding: 12px 24px;
  background: #3b82f6;
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}

.back-home-btn:hover {
  background: #2563eb;
}

/* ===================================
   平板樣式 (768px - 1024px)
   =================================== */

@media (max-width: 1024px) {
  .product-detail-container {
    grid-template-columns: 400px 1fr;
    gap: 30px;
    padding: 24px;
  }

  .product-image-section {
    width: 400px;
  }

  .main-swiper {
    height: 400px;
  }

  .product-title {
    font-size: 22px;
  }

  .price-value {
    font-size: 28px;
  }
}

/* ===================================
   手機樣式 (< 768px)
   =================================== */

@media (max-width: 768px) {
  .product-detail-page {
    padding: 8px;
    /* ⭐ 修正：在手機版也要補上瀏海的高度，不然會被 padding: 8px 蓋掉 */
    padding-top: calc(8px + env(safe-area-inset-top)); 
    box-sizing: border-box;
    overflow-x: hidden;
    width: 100%;
    max-width: 100vw;
  }

  .back-button {
    padding: 8px 16px;
    font-size: 13px;
    margin-bottom: 12px;
  }

  .product-detail-container {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 12px;
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  /* 圖片區域 - 手機版優化 */
  .product-detail-page .product-image-section {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  /* 主圖輪播容器 */
  .product-detail-page .main-swiper {
    height: 280px !important;
    max-height: 280px !important;
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
    border-radius: 8px !important;
  }

  /* 強制覆蓋 Swiper 內部元素 */
  .product-detail-page .main-swiper .swiper-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .product-detail-page .main-swiper .swiper-slide {
    width: 100% !important;
    max-width: 100% !important;
    padding: 8px !important;
    box-sizing: border-box !important;
    flex-shrink: 0 !important;
  }

  .product-detail-page .main-swiper .swiper-slide-active {
    width: 100% !important;
    max-width: 100% !important;
  }

  .product-detail-page .main-product-image {
    max-width: 100% !important;
    max-height: 100% !important;
    width: auto !important;
    height: auto !important;
    object-fit: contain !important;
  }

  /* 縮圖輪播容器 */
  .product-detail-page .thumbs-swiper {
    height: 60px !important;
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
    margin-top: 8px !important;
  }

  /* 強制覆蓋縮圖 Swiper 內部元素 */
  .product-detail-page .thumbs-swiper .swiper-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .product-detail-page .thumbs-swiper .swiper-slide {
    width: auto !important;
    max-width: 25% !important;
    border-radius: 6px !important;
    border-width: 1.5px !important;
    box-sizing: border-box !important;
  }

  .product-detail-page .thumb-image {
    object-fit: contain !important;
    padding: 2px !important;
  }

  /* 商品資訊 */
  .product-title {
    font-size: 20px;
  }

  .rating-section {
    flex-wrap: wrap;
  }

  .price-value {
    font-size: 28px;
  }

  .price-section {
    padding: 16px;
  }

  /* 按鈕改成垂直排列 */
  .action-buttons {
    flex-direction: column;
    gap: 10px;
  }

  .add-to-cart-btn,
  .buy-now-btn {
    width: 100%;
  }

  /* 輪播按鈕 - 縮小 */
  .product-detail-page .main-swiper .swiper-button-prev,
  .product-detail-page .main-swiper .swiper-button-next {
    width: 28px !important;
    height: 28px !important;
  }

