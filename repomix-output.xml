}

.status-processing {
  background: #dbeafe;
  color: #1e40af;
}

.status-shipped {
  background: #e9d5ff;
  color: #6b21a8;
}

.status-completed {
  background: #d1fae5;
  color: #065f46;
}

.status-cancelled {
  background: #fee2e2;
  color: #991b1b;
}

/* ===== 新增：操作按鈕區域 ===== */
.actions {
  display: flex;
  gap: 8px;
}

.btn-detail {
