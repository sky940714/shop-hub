}

.order-id {
  font-weight: 600;
  color: #111827;
  margin-bottom: 0.25rem;
}

.order-items {
  font-size: 0.875rem;
  color: #6b7280;
  margin-bottom: 0.25rem;
}

.order-date {
  font-size: 0.75rem;
  color: #9ca3af;
}

.order-right {
  text-align: right;
}

.order-status {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.order-status.pending {
  background: #fef3c7;
  color: #92400e;
}

.order-status.shipped {
  background: #dbeafe;
  color: #1e40af;
}

.order-status.pickup {
  background: #d1fae5;
