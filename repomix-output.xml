  color: white;
  cursor: pointer;
  border-radius: 0.375rem;
  font-size: 1rem;
  font-weight: 500;
  transition: background-color 0.2s;
  font-family: inherit;
}

.nav-link:hover {
  background: rgba(255, 255, 255, 0.1);
}

.nav-icon {
  width: 1.25rem;
