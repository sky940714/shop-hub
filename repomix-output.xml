<file path="src/pages/admin/styles/OrderManagement.css">
/* pages/admin/styles/OrderManagement.css */

.order-management {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 20px;
}

.page-title {
  font-size: 1.5rem;
  font-weight: bold;
  color: #1f2937;
  margin: 0 0 20px 0;
}

/* ===== 新增：搜尋和篩選區 ===== */
.filter-section {
  display: flex;
  gap: 15px;
  margin-bottom: 20px;
  align-items: center;
  flex-wrap: wrap;
  background: white;
  padding: 20px;
  border-radius: 0.75rem;
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
}

.search-box {
  display: flex;
  gap: 10px;
  flex: 1;
  min-width: 300px;
}

.search-box input {
  flex: 1;
  padding: 10px 15px;
  border: 1px solid #d1d5db;
  border-radius: 0.375rem;
  font-size: 14px;
}

.search-box input:focus {
  outline: none;
  border-color: #2563eb;
}

.btn-search {
  padding: 10px 20px;
  background-color: #2563eb;
  color: white;
  border: none;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: background-color 0.2s;
}

.btn-search:hover {
  background-color: #1d4ed8;
}

.status-filter {
  padding: 10px 15px;
  border: 1px solid #d1d5db;
  border-radius: 0.375rem;
  font-size: 14px;
  cursor: pointer;
  background: white;
}

.status-filter:focus {
  outline: none;
  border-color: #2563eb;
}

.btn-reset {
  padding: 10px 20px;
  background-color: #6b7280;
  color: white;
  border: none;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: background-color 0.2s;
}

.btn-reset:hover {
  background-color: #4b5563;
}

/* ===== 原有樣式 ===== */
.content-card {
  background: white;
  border-radius: 0.75rem;
  padding: 1.5rem;
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
}

/* ===== 新增：載入中 ===== */
.loading {
  text-align: center;
  padding: 60px 20px;
  color: #6b7280;
  font-size: 16px;
}

.table-container {
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

.data-table thead {
  background: #f9fafb;
}

.data-table th {
  text-align: left;
  padding: 0.75rem 1rem;
  font-weight: 600;
  color: #374151;
  font-size: 0.875rem;
  border-bottom: 2px solid #e5e7eb;
}

.data-table tbody tr {
  border-bottom: 1px solid #f3f4f6;
  transition: background-color 0.2s;
}

.data-table tbody tr:hover {
  background: #f9fafb;
}

.data-table td {
  padding: 1rem;
  color: #4b5563;
}

/* ===== 新增：無資料狀態 ===== */
.no-data {
  text-align: center;
  padding: 40px !important;
  color: #9ca3af;
}

.order-id {
  font-weight: 600;
  color: #2563eb;
}

.order-total {
  font-weight: 600;
  color: #059669;
}

/* ===== 新增：付款狀態標籤 ===== */
.badge {
  padding: 4px 12px;
  border-radius: 9999px;
  font-size: 12px;
  font-weight: 600;
}

.badge-unpaid {
  background-color: #fee2e2;
  color: #991b1b;
}

.badge-paid {
  background-color: #d1fae5;
  color: #065f46;
}

.status-select {
  padding: 0.375rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 500;
  border: 1px solid #e5e7eb;
  cursor: pointer;
  background: white;
}

.status-select:focus {
  outline: none;
  border-color: #2563eb;
}

/* ===== 保留原有狀態樣式類別（用於舊版兼容） ===== */
.status-pending {
