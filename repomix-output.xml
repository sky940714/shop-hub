  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e5e7eb;
  color: #9ca3af;
  font-size: 12px;
  border-radius: 0.375rem;
}

.item-info {
  flex: 1;
}

.item-name {
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 5px;
}

.item-variant {
  color: #6b7280;
  font-size: 13px;
  margin-bottom: 5px;
}

.item-price {
  color: #6b7280;
  font-size: 13px;
}

.item-subtotal {
  font-weight: 600;
  color: #059669;
  font-size: 16px;
  min-width: 100px;
  text-align: right;
}

/* ===== 新增：金額明細 ===== */
.amount-detail {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 20px;
  background-color: #f9fafb;
