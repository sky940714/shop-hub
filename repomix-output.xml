/* ===== 新增：詳情區塊 ===== */
.detail-section {
  margin-bottom: 30px;
}

.detail-section h4 {
  margin: 0 0 15px 0;
  padding-bottom: 10px;
  border-bottom: 2px solid #2563eb;
  color: #1f2937;
  font-size: 16px;
  font-weight: 600;
}

.detail-grid {
  display: grid;
