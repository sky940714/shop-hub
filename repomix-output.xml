  .wishlist-page {
    padding-bottom: 2rem;
  }

  .wishlist-container {
    padding: 2rem;
  }

  .wishlist-header {
    padding: 2rem 1.5rem;
  }

  .wishlist-title {
    font-size: 1.875rem;
  }

  .wishlist-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .wishlist-card {
    flex-direction: column;
  }

  .wishlist-product-image {
  width: 100%;
  height: 200px;
  object-fit: contain;
  background-color: #f9fafb;
}

  .wishlist-product-info {
    padding: 1rem;
  }
}

/* 大螢幕 */
@media (min-width: 1024px) {
  .wishlist-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1280px) {
  .wishlist-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
